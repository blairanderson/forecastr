<!doctype html>
<html>
<head>
  <meta charset='utf-8'>
  <title>ShipmentBot Forecasting</title>
  <link href='https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3' crossorigin='anonymous'>
</head>
<body>
<main class='container'>
  <h1><a class="text-decoration-none display-1" href="https://forecast.shipmentbot.com/">ShipmentBot Forecasting!</a></h1>
  <div class="row align-items-center">
    <div class="col-12 col-sm-7">
      <%= yield %>
    </div>
    <div class="col-12 col-sm-5">
      <form action="/test" method="post">
        <div class="mb-3">
          <p><small class="text-secondary">
            This should be pasted directly from an excel/csv file. two columns with date, value. ignore the header.
          </small></p>
          <label for="series" class="form-label">Series</label>
          <textarea class="form-control" id="series" name="series" rows="10">
<%= (series ||= {}).sort_by{|k,v| Date.parse(k) }.map{|k,v| [k,v].join("\t") }.join("\n") %>
          </textarea>
        </div>
        <div class="mb-3">
          <div class="input-group">
            <label for="strptime" class="input-group-text">Date.strptime format:</label>
            <input type="text" class="form-control" id="strptime" name="strptime" value="%m/%d/%Y">
          </div>
          <div class="input-group">
            <label for="count" class="input-group-text">Forecast Count:</label>
            <input type="number" class="form-control" id="count" name="count" value="100">
            <input type="submit" class="btn btn-primary" value="Submit"/>
          </div>
        </div>
      </form>
    </div>
  </div>
</main>
</body>
</html>